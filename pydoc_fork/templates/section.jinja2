<section class="section">
    <div class="section-header {{ section_class|default('theme-section') }}">
        <h2>{{ title }}</h2>
    </div>
    <div class="section-body">
        {% if prelude %}
        <div class="section-prelude">
            <div class="marginalia"><tt>{{ marginalia }}</tt></div>
            <div class="prelude-content">{{ prelude }}</div>
        </div>
        {% endif %}
        <div class="section-content">
            {% if not prelude %}
            <div class="marginalia"><tt>{{ marginalia }}</tt></div>
            {% endif %}
            <div class="main-content">
                {{ contents }}
            </div>
        </div>
    </div>
</section>
